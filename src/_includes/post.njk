<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ title }} · Firat Barca</title>
<meta name="description" content="{{ summary }}" />
<meta name="author" content="{{ site.author }}" />
<link rel="canonical" href="{{ site.url }}{{ page.url }}" />
<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
<link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
<link rel="alternate" type="application/atom+xml" title="Firat Barca · Blog" href="/feed.xml" />

<!-- Open Graph -->
<meta property="og:type" content="article" />
<meta property="og:title" content="{{ title }}" />
<meta property="og:description" content="{{ summary }}" />
<meta property="og:url" content="{{ site.url }}{{ page.url }}" />
<meta property="og:site_name" content="{{ site.name }}" />
<meta property="og:locale" content="{{ site.locale }}" />
<meta property="og:image" content="{{ site.url }}{{ cover or site.image }}" />
<meta property="article:published_time" content="{{ date | isoDate }}" />
<meta property="article:author" content="{{ site.author }}" />
<meta property="article:section" content="{{ tag }}" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ title }}" />
<meta name="twitter:description" content="{{ summary }}" />
<meta name="twitter:image" content="{{ site.url }}{{ cover or site.image }}" />

<!-- Structured data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "description": {{ summary | dump | safe }},
  "image": "{{ site.url }}{{ cover or site.image }}",
  "datePublished": "{{ date | isoDate }}",
  "dateModified": "{{ date | isoDate }}",
  "url": "{{ site.url }}{{ page.url }}",
  "mainEntityOfPage": "{{ site.url }}{{ page.url }}",
  "author": { "@type": "Person", "name": "{{ site.author }}", "url": "{{ site.url }}/" },
  "publisher": { "@type": "Person", "name": "{{ site.author }}", "url": "{{ site.url }}/" }
}
</script>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/blog/style.css" />
<!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "5c83b0428a8146f18271b4e51332f02a"}'></script><!-- End Cloudflare Web Analytics -->
</head>
<body>

<div class="bar">
  <div class="in">
    <a class="brand" href="/index.html">Firat Barca<span>.</span></a>
    <a class="back" href="/blog/">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
      All posts
    </a>
  </div>
</div>

<article>
  <span class="post-tag">{{ tag }}</span>
  <h1>{{ title }}</h1>
  <div class="post-meta">By Firat Barca · {{ date | postDate }} · {{ content | readingTime }} min read</div>

  {% if cover %}<img src="{{ cover }}" alt="{{ title }}" style="width:100%;border:1px solid var(--line);margin:0 0 2rem;" onerror="this.style.display='none'" />{% endif %}

  {{ content | safe }}

  <div class="newsletter" aria-labelledby="nl-h-post">
    <p class="lbl">Occasional dispatches</p>
    <h3 id="nl-h-post">New posts, straight to your inbox</h3>
    <p>ESG &amp; sustainability reporting, climate policy, and the tools I build. No spam, unsubscribe anytime.</p>
    <!-- Kit form (id 9692717, uid 48a6952f49) — plain POST, public id only, no API key. -->
    <form action="https://app.kit.com/forms/9692717/subscriptions" method="post" data-sv-form="9692717" data-uid="48a6952f49">
      <label class="vh" for="nl-email-post">Your email address</label>
      <input id="nl-email-post" name="email_address" type="email" inputmode="email" autocomplete="email" placeholder="you@email.com" required>
      <button type="submit">Subscribe</button>
    </form>
    <p class="fine">No spam · unsubscribe anytime.</p>
  </div>

  <hr />
  <p><em>Working on something in this space? I'd be glad to compare notes. <a href="/index.html#contact">Get in touch</a>.</em></p>

  <div class="share">
    <span class="lbl">Share</span>
    <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ (site.url + page.url) | urlencode }}" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14ZM8.34 18.34v-7.2H6.06v7.2h2.28ZM7.2 10.1a1.32 1.32 0 1 0 0-2.64 1.32 1.32 0 0 0 0 2.64Zm11.14 8.24v-4.13c0-2.2-1.18-3.23-2.75-3.23a2.37 2.37 0 0 0-2.15 1.18v-1.02h-2.28v7.2h2.28v-3.98c0-1.05.2-2.07 1.5-2.07s1.32 1.2 1.32 2.14v3.91h2.28Z"/></svg>
      LinkedIn
    </a>
    <button type="button" id="copy-link" data-url="{{ site.url }}{{ page.url }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      <span id="copy-link-label">Copy link</span>
    </button>
  </div>

  <div class="post-foot">
    <a class="home" href="/index.html">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
      Back to firatbarca
    </a>
    <span class="who">Firat Barca · Sustainability &amp; ESG · Ph.D.</span>
  </div>
</article>

<script>
  // Copy-link button on the share row; falls back to a prompt where the
  // Clipboard API is unavailable (non-HTTPS or very old browsers).
  (function(){
    var btn = document.getElementById('copy-link'); if (!btn) return;
    var label = document.getElementById('copy-link-label');
    btn.addEventListener('click', function(){
      var url = btn.getAttribute('data-url');
      function done(){ label.textContent = 'Copied!'; setTimeout(function(){ label.textContent = 'Copy link'; }, 1600); }
      if (navigator.clipboard && navigator.clipboard.writeText){
        navigator.clipboard.writeText(url).then(done, function(){ window.prompt('Copy this link:', url); });
      } else {
        window.prompt('Copy this link:', url);
      }
    });
  })();
</script>

</body>
</html>
