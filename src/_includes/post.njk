<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ title }} — Firat Barca</title>
<meta name="description" content="{{ summary }}" />
<meta name="author" content="{{ site.author }}" />
<link rel="canonical" href="{{ site.url }}{{ page.url }}" />

<!-- Open Graph -->
<meta property="og:type" content="article" />
<meta property="og:title" content="{{ title }}" />
<meta property="og:description" content="{{ summary }}" />
<meta property="og:url" content="{{ site.url }}{{ page.url }}" />
<meta property="og:site_name" content="{{ site.name }}" />
<meta property="og:locale" content="{{ site.locale }}" />
<meta property="og:image" content="{{ site.url }}{{ cover or site.image }}" />
<meta property="article:published_time" content="{{ date | isoDate }}" />
<meta property="article:author" content="{{ site.author }}" />
<meta property="article:section" content="{{ tag }}" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ title }}" />
<meta name="twitter:description" content="{{ summary }}" />
<meta name="twitter:image" content="{{ site.url }}{{ cover or site.image }}" />

<!-- Structured data -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "description": {{ summary | dump | safe }},
  "image": "{{ site.url }}{{ cover or site.image }}",
  "datePublished": "{{ date | isoDate }}",
  "dateModified": "{{ date | isoDate }}",
  "url": "{{ site.url }}{{ page.url }}",
  "mainEntityOfPage": "{{ site.url }}{{ page.url }}",
  "author": { "@type": "Person", "name": "{{ site.author }}", "url": "{{ site.url }}/" },
  "publisher": { "@type": "Person", "name": "{{ site.author }}", "url": "{{ site.url }}/" }
}
</script>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/blog/style.css" />
<!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "5c83b0428a8146f18271b4e51332f02a"}'></script><!-- End Cloudflare Web Analytics -->
</head>
<body>

<div class="bar">
  <div class="in">
    <a class="brand" href="/index.html">Firat Barca<span>.</span></a>
    <a class="back" href="/blog/">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
      All posts
    </a>
  </div>
</div>

<article>
  <span class="post-tag">{{ tag }}</span>
  <h1>{{ title }}</h1>
  <div class="post-meta">By Firat Barca · {{ date | postDate }} · {{ content | readingTime }} min read</div>

  {% if cover %}<img src="{{ cover }}" alt="{{ title }}" style="width:100%;border:1px solid var(--line);margin:0 0 2rem;" onerror="this.style.display='none'" />{% endif %}

  {{ content | safe }}

  <hr />
  <p><em>Working on something in this space? I'd be glad to compare notes — <a href="/index.html#contact">get in touch</a>.</em></p>

  <div class="post-foot">
    <a class="home" href="/index.html">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
      Back to firatbarca
    </a>
    <span class="who">Firat Barca · Sustainability &amp; ESG · Ph.D.</span>
  </div>
</article>

</body>
</html>
